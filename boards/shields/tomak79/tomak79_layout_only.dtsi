            , <&key_physical_attrs 100 100 1375  425       0    0    0>
            , <&key_physical_attrs 100 100 1475  425       0    0    0>
            , <&key_physical_attrs 100 100 1575  425       0    0    0>
            , <&key_physical_attrs 175 100 1675  425       0    0    0>
            , <&key_physical_attrs 100 100 1875  475       0    0    0>

            , <&key_physical_attrs 125 100    0  525       0    0    0>
            , <&key_physical_attrs 100 100  125  525       0    0    0>
            , <&key_physical_attrs 125 100  225  525       0    0    0>
            , <&key_physical_attrs 150 100 1475  525       0    0    0>
