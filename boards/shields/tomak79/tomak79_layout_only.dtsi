            , <&key_physical_attrs 100 100  400  125       0    0    0>
            , <&key_physical_attrs 100 100  500  125       0    0    0>
            , <&key_physical_attrs 100 100  600  125       0    0    0>
            , <&key_physical_attrs 100 100  700  125       0    0    0>
            , <&key_physical_attrs 100 100 1150  125       0    0    0>
            , <&key_physical_attrs 100 100 1250  125       0    0    0>
            , <&key_physical_attrs 100 100 1350  125       0    0    0>
            , <&key_physical_attrs 100 100 1450  125       0    0    0>
            , <&key_physical_attrs 100 100 1550  125       0    0    0>
            , <&key_physical_attrs 100 100 1650  125       0    0    0>
            , <&key_physical_attrs 200 100 1750  125       0    0    0>
            , <&key_physical_attrs 100 100 1975  125       0    0    0>

            , <&key_physical_attrs 150 100    0  225       0    0    0>
            , <&key_physical_attrs 100 100  150  225       0    0    0>
            , <&key_physical_attrs 100 100  250  225       0    0    0>
