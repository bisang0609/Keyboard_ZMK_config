            , <&key_physical_attrs 100 100  650  225       0    0    0>
            , <&key_physical_attrs 100 100 1100  225       0    0    0>
            , <&key_physical_attrs 100 100 1200  225       0    0    0>
            , <&key_physical_attrs 100 100 1300  225       0    0    0>
            , <&key_physical_attrs 100 100 1400  225       0    0    0>
            , <&key_physical_attrs 100 100 1500  225       0    0    0>
            , <&key_physical_attrs 100 100 1600  225       0    0    0>
            , <&key_physical_attrs 100 100 1700  225       0    0    0>
            , <&key_physical_attrs 150 100 1800  225       0    0    0>

            , <&key_physical_attrs 175 100    0  325       0    0    0>
            , <&key_physical_attrs 100 100  175  325       0    0    0>
            , <&key_physical_attrs 100 100  275  325       0    0    0>
            , <&key_physical_attrs 100 100  375  325       0    0    0>
